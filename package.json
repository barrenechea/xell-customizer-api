{
  "name": "xell-customizer-api",
  "scripts": {
    "start": "bun src/index.ts",
    "dev": "bun --hot src/index.ts",
    "build": "bun build --production ./src/index.ts --compile --target=bun --outfile=./xell-api",
    "check": "biome check .",
    "check:fix": "biome check --write ."
  },
  "dependencies": {
    "@hono/zod-validator": "^0.7.4",
    "@octokit/rest": "^22.0.0",
    "@paralleldrive/cuid2": "^2.2.2",
    "hono": "^4.9.11",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.2.5",
    "@types/bun": "^1.3.0",
    "typescript": "^5.9.3"
  }
}
